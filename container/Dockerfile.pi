# ShogAgent Container (pi-coding-agent edition)
# Runs pi-coding-agent in isolated Linux VM with browser automation

FROM node:22-slim

# Install system dependencies for Chromium
RUN apt-get update && apt-get install -y \
    chromium \
    fonts-liberation \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
    libgbm1 \
    libnss3 \
    libatk-bridge2.0-0 \
    libgtk-3-0 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libasound2 \
    libpangocairo-1.0-0 \
    libcups2 \
    libdrm2 \
    libxshmfence1 \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Set Chromium path for agent-browser
ENV AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Install agent-browser globally (no claude-code needed for pi edition)
RUN npm install -g agent-browser mmx-cli

# Create app directory
WORKDIR /app

# Copy package files first for better caching
COPY package.json ./

# Install dependencies
RUN npm install

# Copy built-in skills and schema into the image
COPY skills/ /app/skills/
COPY schema/ /app/schema/
COPY wiki-config.json /app/wiki-config.json
COPY system-prompt.md /app/system-prompt.md

# Install extensions with npm dependencies (before switching to non-root user)
COPY extensions/ /tmp/extensions/
RUN for dir in /tmp/extensions/*/; do \
      if [ -f "$dir/package.json" ]; then \
        cd "$dir" && npm install --omit=dev; \
      fi; \
    done

# Allow extensions to resolve packages from /app/node_modules
ENV NODE_PATH=/app/node_modules
ENV PATH="/app/node_modules/.bin:${PATH}"

# Create workspace directories
RUN mkdir -p /workspace/group /workspace/global /workspace/extra /workspace/ipc/messages /workspace/ipc/tasks

# Create entrypoint script (before USER node — root needs write access to /app)
# Subdirectories in /home/node/.pi/agent/ use cp -n (no-clobber) so host mounts are preserved
RUN printf '#!/bin/bash\nset -e\n# Sync built-in extensions (overwrite stale copies)\nmkdir -p /home/node/.pi/agent/extensions\nfor dir in /tmp/extensions/*/; do\n  name=$(basename "$dir")\n  rm -rf "/home/node/.pi/agent/extensions/$name"\n  cp -r "$dir" "/home/node/.pi/agent/extensions/$name"\ndone\n# Sync built-in skills to pi discoverable path\nmkdir -p /home/node/.pi/agent/skills\nfor dir in /app/skills/*/; do\n  name=$(basename "$dir")\n  rm -rf "/home/node/.pi/agent/skills/$name"\n  cp -r "$dir" "/home/node/.pi/agent/skills/$name"\ndone\n# Sync global schema and wiki-config (no-clobber: host mount takes precedence)\nmkdir -p /workspace/group/schema\ncp -n /app/schema/* /workspace/group/schema/ 2>/dev/null || true\ncp -n /app/wiki-config.json /workspace/group/wiki-config.json 2>/dev/null || true\n# Symlink group skills into .pi directory for auto-discovery\nif [ -d /workspace/group/skills ]; then\n  mkdir -p /workspace/group/.pi\n  ln -sfn /workspace/group/skills /workspace/group/.pi/skills\nfi\n# Launch pi in RPC mode\nexec pi --mode rpc \\\n  --append-system-prompt "$(cat /app/system-prompt.md)" \\\n  --model "${MODEL:-openai-codex/gpt-5.4}"\n' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

# Set ownership so /home is writable
RUN chown -R node:node /workspace && chmod 777 /home/node

# Create pi agent directory — empty at build time so host volume mounts work.
# Root ownership so the directory itself is accessible when a volume is mounted.
RUN mkdir -p /home/node/.pi/agent

# Switch to non-root user (entrypoint and pi run as node)
USER node

# Set working directory to group workspace
WORKDIR /workspace/group

# Entry point: pi runs in RPC mode, reading JSON commands from stdin, emitting JSON events to stdout
ENTRYPOINT ["/app/entrypoint.sh"]
