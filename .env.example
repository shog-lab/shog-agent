# Assistant name (used as trigger word: @shog)
ASSISTANT_NAME=shog

# Model configuration (provider/model-name)
# Examples: openai-codex/gpt-5.2-codex, anthropic/claude-sonnet-4-6, openai/gpt-4o
MODEL=openai-codex/gpt-5.2-codex

# --- Channels (configure at least one) ---

# DingTalk
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# WeChat (iLink Bot)
# Requires QR code scan — see data/weixin-auth.json

# --- Optional API keys (passed to agent containers) ---

# Jimeng image generation
JIMENG_ACCESS_KEY=
JIMENG_SECRET_KEY=

# WeChat Official Account (for wechat-publish skill)
WECHAT_APPID=
WECHAT_SECRET=
